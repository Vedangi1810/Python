🟢 7. Retry decorator (VERY IMPRESSIVE)
import time

def retry(func):
    def wrapper(*args, **kwargs):
        for _ in range(3):
            try:
                return func(*args, **kwargs)
            except:
                time.sleep(2)
    return wrapper
