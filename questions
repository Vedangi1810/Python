🟢 5. Find duplicate files in a directory

👉 Tests hashing

import hashlib, os

hashes = {}

for root, _, files in os.walk("data"):
    for f in files:
        path = os.path.join(root, f)
        with open(path, "rb") as file:
            h = hashlib.md5(file.read()).hexdigest()
            hashes.setdefault(h, []).append(path)

print([v for v in hashes.values() if len(v) > 1])
